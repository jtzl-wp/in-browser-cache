#: includes/class-jtzl-sw-admin.php:134
msgid "Enable In-Browser Caching"
msgstr ""

#: includes/class-jtzl-sw-admin.php:142
msgid "Disable for Logged-in Users (GDPR)"
msgstr ""

#: includes/class-jtzl-sw-admin.php:146
msgid "Disable caching for logged-in users to ensure GDPR compliance. When enabled, the service worker will be unregistered and all caches cleared for authenticated users."
msgstr ""

#: includes/class-jtzl-sw-admin.php:153
msgid "Maximum Cache Size (MB)"
msgstr ""

#: includes/class-jtzl-sw-admin.php:157
msgid "Maximum amount of storage space (in megabytes) that the in-browser cache can use. When this limit is reached, older cached items will be removed."
msgstr ""

#: includes/class-jtzl-sw-admin.php:162
msgid "Cache Lifetime (Days)"
msgstr ""

#: includes/class-jtzl-sw-admin.php:166
msgid "How long cached items should be stored before being considered stale and refreshed. Longer lifetimes reduce server requests but may serve outdated content."
msgstr ""

#: includes/class-jtzl-sw-admin.php:172
msgid "Performance Settings"
msgstr ""

#: includes/class-jtzl-sw-admin.php:173
msgid "Configure how often Service Workers check for updates. Lower values provide faster response but increase server load."
msgstr ""

#: includes/class-jtzl-sw-admin.php:176
msgid "Cache Version Check Interval (Minutes)"
msgstr ""

#: includes/class-jtzl-sw-admin.php:180
msgid "How often Service Workers check if caches should be cleared (1-60 minutes). Lower values clear caches faster but increase server requests."
msgstr ""

#: includes/class-jtzl-sw-admin.php:185
msgid "Metrics Sync Interval (Minutes)"
msgstr ""

#: includes/class-jtzl-sw-admin.php:189
msgid "How often Service Workers send usage metrics to the server (1-60 minutes). Higher values reduce server load."
msgstr ""

#: includes/class-jtzl-sw-admin.php:194
msgid "Health Check Interval (Minutes)"
msgstr ""

#: includes/class-jtzl-sw-admin.php:198
msgid "How often Service Workers check if the plugin is still active (5-120 minutes). Used for automatic cleanup when plugin is deactivated."
msgstr ""

#: includes/class-jtzl-sw-admin.php:206
msgid "Cache Management"
msgstr ""

#: includes/class-jtzl-sw-admin.php:208
msgid "Clear All User Caches:"
msgstr ""

#: includes/class-jtzl-sw-admin.php:208
msgid "This will clear the in-browser caches for all website visitors, not just your browser. Use this when you've updated critical assets and want to ensure all users get the latest version."
msgstr ""

#: includes/class-jtzl-sw-admin.php:213
msgid "Clear All User Caches"
msgstr ""

#: includes/class-jtzl-sw-admin.php:214
msgid "This action will increment the cache version, causing all users' Service Workers to automatically clear their caches within a few minutes."
msgstr ""

